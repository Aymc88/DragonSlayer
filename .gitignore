# ============================================
# T-data Project .gitignore
# ============================================

# --- 模型权重文件（体积过大，不上传 GitHub）---
*.bin
*.gguf
*.safetensors
*.pth
*.pt
*.ckpt
*.pkl
*.h5

# --- 模型缓存与临时文件 ---
*.npy
*.npz
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# --- 虚拟环境 ---
dash_venv/
venv/
env/
.venv/
*.egg-info/

# --- 日志与输出文件 ---
*.log
logs/
output/
results/
checkpoints/

# --- macOS 系统文件 ---
.DS_Store
.AppleDouble
.LSOverride

# --- IDE 与编辑器文件 ---
.vscode/
.idea/
*.swp
*.swo

# --- 环境变量与敏感信息 ---
.env
.env.*
secrets.json
api_keys.py

# --- Jupyter Notebook 缓存 ---
.ipynb_checkpoints/
*.ipynb

# --- 测试与调试脚本（可选保留）---
test.py
